# Single source of truth for live FlashOS release and build-tool versions.
# Run `scripts/sync_versions.sh --write` after changing a value, then commit
# the manifest and its mechanically synchronized consumers together.
# FLASHOS_RUST_VERSION also drives the sub-project toolchains under components/*
# (e.g. FlashShell); each sub-project keeps its own product release version.
FLASHOS_RELEASE_VERSION=0.8.0
FLASHOS_RUST_VERSION=1.97.1
FLASHOS_QEMU_VERSION=11.0.1
