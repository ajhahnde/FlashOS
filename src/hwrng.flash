// Call-site adapter for the Rust-owned kernel entropy fallback.
//
// The remaining syscall module passes a Flash slice here. The adapter lowers
// it to the pointer/length pair carried by the C ABI; all generator state,
// mixing, initialization, and self-test logic lives in Rust.

pub const Source = enum {
    fallback,
}

extern fn fos_hwrng_fill(buf [*]mut u8, len usize) void

pub fn fill(buf []mut u8) Source {
    fos_hwrng_fill(buf.ptr, buf.len)
    return .fallback
}
